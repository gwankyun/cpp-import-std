{
    "version": 10,
    "configurePresets": [
        {
            "name": "graphviz",
            "hidden": true,
            "graphviz": "${sourceDir}/graphviz/${presetName}.dot"
        },
        {
            "name": "base",
            "inherits": [],
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "USE_MODULE": "ON",
                "USE_IMPORT_STD_UUID": "OFF",
                "USE_IMPORT_STD": "ON",
                "USE_EXPORT_IMPORT_HEADER": "OFF",
                "USE_NINJA": "OFF",
                "USE_TRY_COMPILE": "ON"
            }
        },
        {
            "name": "use-module-disable",
            "hidden": true,
            "cacheVariables": {
                "USE_MODULE": "OFF"
            }
        },
        {
            "name": "use-import-std-disable",
            "hidden": true,
            "cacheVariables": {
                "USE_IMPORT_STD": "OFF"
            }
        },
        {
            "name": "ninja",
            "inherits": "base",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "USE_IMPORT_STD_UUID": "ON",
                "USE_NINJA": "ON"
            }
        },
        {
            "name": "msvc",
            "inherits": "base",
            "description": "Visual Studio 18 2026",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64"
        },
        {
            "name": "clang",
            "inherits": "ninja",
            "environment": {
                "PATH": "$env{LLVM_MINGW_ROOT}/bin;$penv{PATH}"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "$env{LLVM_MINGW_ROOT}/bin/clang.exe",
                "CMAKE_CXX_COMPILER": "$env{LLVM_MINGW_ROOT}/bin/clang++.exe",
                "COMPILER_BIN": "$env{LLVM_MINGW_ROOT}/bin",
                "CMAKE_OBJDUMP": "$env{LLVM_MINGW_ROOT}/bin/llvm-objdump.exe"
            }
        },
        {
            "name": "gcc",
            "inherits": [
                "use-import-std-disable",
                "ninja"
            ],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "$env{MINGW64_ROOT}/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "$env{MINGW64_ROOT}/bin/g++.exe",
                "COMPILER_BIN": "$env{MINGW64_ROOT}/bin"
            },
            "environment": {
                "PATH": "$env{MINGW64_ROOT}/bin;$penv{PATH}"
            }
        },
        {
            "name": "clangcl",
            "inherits": [
                "use-module-disable",
                "use-import-std-disable",
                "msvc"
            ],
            "description": "Clang CL (Visual Studio, no modules)",
            "toolset": "ClangCL"
        },
        {
            "name": "clangcl-ninja",
            "inherits": [
                "use-import-std-disable",
                "ninja"
            ],
            "description": "Clang CL (Ninja, with modules)",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "$env{VS_LLVM_ROOT}/bin/clang-cl.exe",
                "CMAKE_CXX_COMPILER": "$env{VS_LLVM_ROOT}/bin/clang-cl.exe"
            },
            "environment": {
                "PATH": "$env{VS_LLVM_ROOT}/bin;$penv{PATH}"
            }
        }
    ]
}