{
    "version": 9,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "USE_MODULE": "ON",
                "USE_IMPORT_STD_UUID": "ON",
                "USE_IMPORT_STD": "ON"
            }
        },
        {
            "name": "ninja",
            "inherits": "base",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "USE_IMPORT_STD_UUID": "ON"
            }
        },
        {
            "name": "msvc",
            "inherits": "base",
            "description": "Visual Studio 18 2026",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "cacheVariables": {
                "USE_IMPORT_STD_UUID": "OFF"
            }
        },
        {
            "name": "clang",
            "inherits": "ninja",
            "toolchainFile": "${sourceDir}/toolchainFile/clang.cmake",
            "environment": {
                "PATH": "$env{LLVM_MINGW_ROOT}/bin;$penv{PATH}"
            },
            "cacheVariables": {
                "COMPILER_BIN": "$env{LLVM_MINGW_ROOT}/bin"
            }
        },
        {
            "name": "gcc",
            "inherits": "ninja",
            "toolchainFile": "${sourceDir}/toolchainFile/gcc.cmake",
            "cacheVariables": {
                "USE_IMPORT_STD": "OFF",
                "COMPILER_BIN": "$env{MINGW64_ROOT}/bin"
            },
            "environment": {
                "PATH": "$env{MINGW64_ROOT}/bin;$penv{PATH}"
            }
        },
        {
            "name": "clangcl",
            "inherits": "msvc",
            "description": "Clang CL (Visual Studio)",
            "toolset": "ClangCL",
            "cacheVariables": {
                "USE_MODULE": "OFF",
                "USE_IMPORT_STD_UUID": "OFF",
                "USE_IMPORT_STD": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "msvc",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "clang",
            "configurePreset": "clang",
            "configuration": "Debug"
        },
        {
            "name": "gcc",
            "configurePreset": "gcc",
            "configuration": "Debug"
        },
        {
            "name": "clangcl",
            "configurePreset": "clangcl",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "msvc",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "clang",
            "configurePreset": "clang",
            "configuration": "Debug"
        },
        {
            "name": "gcc",
            "configurePreset": "gcc",
            "configuration": "Debug"
        },
        {
            "name": "clangcl",
            "configurePreset": "clangcl",
            "configuration": "Debug"
        }
    ],
    "workflowPresets": [
        {
            "name": "msvc",
            "steps": [
                { "type": "configure", "name": "msvc" },
                { "type": "build", "name": "msvc" },
                { "type": "test", "name": "msvc" }
            ]
        },
        {
            "name": "clang",
            "steps": [
                { "type": "configure", "name": "clang" },
                { "type": "build", "name": "clang" },
                { "type": "test", "name": "clang" }
            ]
        },
        {
            "name": "clangcl",
            "steps": [
                { "type": "configure", "name": "clangcl" },
                { "type": "build", "name": "clangcl" },
                { "type": "test", "name": "clangcl" }
            ]
        },
        {
            "name": "gcc",
            "steps": [
                { "type": "configure", "name": "gcc" },
                { "type": "build", "name": "gcc" },
                { "type": "test", "name": "gcc" }
            ]
        }
    ]
}