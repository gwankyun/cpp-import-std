{
    "version": 10,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}"
        },
        {
            "name": "msvc",
            "inherits": "base",
            "description": "Visual Studio 18 2026",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64"
        },
        {
            "name": "clang-mingw",
            "inherits": "base",
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "$penv{LLVM_MINGW_ROOT}/bin/clang.exe",
                "CMAKE_CXX_COMPILER": "$penv{LLVM_MINGW_ROOT}/bin/clang++.exe"
            },
            "environment": {
                "PATH": "$penv{LLVM_MINGW_ROOT}/bin;$penv{PATH}"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "msvc",
            "configurePreset": "msvc",
            "configuration": "Release"
        },
        {
            "name": "clang-mingw",
            "configurePreset": "clang-mingw",
            "configuration": "Release"
        }
    ]
}