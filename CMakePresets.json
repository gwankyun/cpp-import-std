{
    "version": 9,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "USE_IMPORT_STD_UUID": "ON",
                "USE_IMPORT_STD": "ON"
            }
        },
        {
            "name": "ninja",
            "inherits": "base",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "USE_IMPORT_STD_UUID": "ON"
            }
        },
        {
            "name": "msvc",
            "inherits": "base",
            "description": "Visual Studio 18 2026",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "cacheVariables": {
                "USE_IMPORT_STD_UUID": "OFF"
            }
        },
        {
            "name": "clang",
            "inherits": "ninja",
            "toolchainFile": "${sourceDir}/toolchainFile/clang.cmake",
            "environment": {
                "PATH": "$env{LLVM_MINGW_ROOT}/bin;$penv{PATH}"
            },
            "cacheVariables": {
                "COMPILER_BIN": "$env{LLVM_MINGW_ROOT}/bin"
            }
        },
        {
            "name": "gcc",
            "inherits": "ninja",
            "toolchainFile": "${sourceDir}/toolchainFile/gcc.cmake",
            "cacheVariables": {
                "USE_IMPORT_STD": "OFF",
                "COMPILER_BIN": "$env{MINGW64_ROOT}/bin"
            },
            "environment": {
                "PATH": "$env{MINGW64_ROOT}/bin;$penv{PATH}"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "msvc",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "clang",
            "configurePreset": "clang",
            "configuration": "Debug"
        },
        {
            "name": "gcc",
            "configurePreset": "gcc",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "msvc",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "clang",
            "configurePreset": "clang",
            "configuration": "Debug"
        },
        {
            "name": "gcc",
            "configurePreset": "gcc",
            "configuration": "Debug"
        }
    ]
}